{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://newsroom.local/schemas/evidence_package_v1.schema.json",
  "title": "Newsroom evidence package v1",
  "type": "object",
  "required": [
    "schema_version",
    "encoding_version",
    "digest_algorithm",
    "provenance",
    "claims",
    "component_versions"
  ],
  "properties": {
    "schema_version": { "const": "evidence_package_v1" },
    "encoding_version": { "const": "rfc8785-restricted-v1" },
    "digest_algorithm": { "const": "sha256" },
    "provenance": {
      "type": "object",
      "required": ["run_id", "story_id", "source_refs"],
      "properties": {
        "run_id": { "type": "string", "minLength": 1 },
        "story_id": { "type": "string", "minLength": 1 },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["source_id", "source_digest", "rights_status"],
            "properties": {
              "source_id": { "type": "string", "minLength": 1 },
              "source_digest": {
                "type": "string",
                "pattern": "^sha256:[0-9a-f]{64}$"
              },
              "rights_status": {
                "enum": ["PERMITTED", "PERMITTED_METADATA_ONLY", "UNKNOWN", "PROHIBITED"]
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim_id", "evidence_refs"],
        "properties": {
          "claim_id": { "type": "string", "minLength": 1 },
          "evidence_refs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          }
        },
        "additionalProperties": false
      }
    },
    "component_versions": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": false
}
