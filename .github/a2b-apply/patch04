+            object_issuer=object_issuer,
+            admission_registry=admission_registry,
+            rights_policies=rights_policies,
+            hydration_policies=hydration_policies,
+            cas=cas,
+        )
+
+
+__all__ = ["_GovernedObjectAuthorityStore"]
