+        clock: Any = UtcTimestamp.now,
+    ) -> None:
+        super().__init__(
+            path,
+            issuer=issuer,
+            command_registry=command_registry,
+            payload_schemas=payload_schemas,
+            command_service_version=command_service_version,
+            busy_timeout_ms=busy_timeout_ms,
