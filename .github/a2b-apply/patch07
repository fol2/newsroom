hydration.  This is
+                    # deterministic cleanup after an interrupted physical unlink.
+                    self._cas.unlink(identity)
+
+    @staticmethod
+    def _latest_deletion_row(
+        conn: sqlite3.Connection, blob_digest: str
+    ) -> sqlite3.Row | None:
+        return conn.execute(
+            "SELECT d.deletion_id,d.reason_code,d.created_at,"
+            "h.current_version,v.state,v.event_id,v.recorded_at,v.error_code "
+            "FROM object_deletions d "
+            "JOIN object_deletion_heads h ON h.deletion_id=d.deletion_id "
+            "JOIN object_deletion_versions v "
+            "ON v.deletion_id=h.deletion_id "
+            "AND v.lifecycle_version=h.current_version "
+            "WHERE d.blob_digest=? ORDER BY d.created_at DESC LIMIT 1",
+            (blob_digest,),
+        ).fetchone()
+
+    def _current_admission_row(
+        self,
+        conn: sqlite3.Connection,
+        admission_id: str,
+        *,
+        now: UtcTimestamp,
+        require_active: bool = True,
+        require_bytes: bool = True,
+    ) -> sqlite3.Row:
+        row = conn.execute(
+            "SELECT a.*,h.current_version AS admission_lifecycle_version,"
+            "v.state AS admission_state,v.event_id AS admission_event_id,"
+            "r.canonical_digest AS rights_decision_digest,r.allowed AS rights_allowed,"
+            "r.reason_code AS rights_reason_code,r.decided_at AS rights_decided_at,"
+            "r.valid_from AS rights_valid_from,r.valid_until AS rights_valid_until,"
+            "bi.size_bytes AS size_bytes,bh.current_version AS blob_lifecycle_version,"
+            "bv.state AS blob_state,bv.integrity_state AS blob_integrity_state "
+            "FROM object_admissions a "
+            "JOIN object_admission_heads h ON h.admission_id=a.admission_id "
+            "JOIN object_admission_versions v "
+            "ON v.admission_id=h.admission_id "
+            "AND v.lifecycle_version=h.current_version "
+            "JOIN object_rights_decisions r "
+            "ON r.rights_decision_id=a.rights_decision_id "
+            "JOIN blob_identities bi ON bi.blob_digest=a.blob_digest "
+            "JOIN blob_lifecycle_heads bh ON bh.blob_digest=a.blob_digest "
+            "JOIN blob_lifecycle_versions bv "
+            "ON bv.blob_digest=bh.blob_digest "
+            "AND bv.lifecycle_version=bh.current_version "
+            "WHERE a.admission_id=?",
+            (admission_id,),
+        ).fetchone()
+        if row is None:
+            raise KeyError(admission_id)
+        if require_active and str(row["admission_state"]) != AdmissionState.ACTIVE.value:
+            raise ObjectAdmissionDenied("OBJECT_ADMISSION_NOT_ACTIVE")
+        decided_at = UtcTimestamp.parse(str(row["rights_decided_at"]))
+        valid_from = UtcTimestamp.parse(str(row["rights_valid_from"]))
+        valid_until = (
+            None
+            if row["rights_valid_until"] is None
+            else UtcTimestamp.parse(str(row["rights_valid_until"]))
+        )
+        if not bool(row["rights_allowed"]):
+            raise ObjectAdmissionDenied(str(row["rights_reason_code"]))
+        if now.value < decided_at.value:
+            raise ObjectAdmissionDenied("RIGHTS_DECISION_NOT_YET_EFFECTIVE")
+        if now.value < valid_from.value:
+            raise ObjectAdmissionDenied("RIGHTS_NOT_YET_VALID")
+        if valid_until is not None and now.value >= valid_until.value:
+            raise ObjectAdmissionDenied("RIGHTS_EXPIRED")
+        admission_valid_from = UtcTimestamp.parse(str(row["valid_from"]))
+        admission_valid_until = (
+            None
+            if row["valid_until"] is None
+            else UtcTimestamp.parse(str(row["valid_until"]))
+        )
+        if now.value < admission_valid_from.value:
+            raise ObjectAdmissionDenied("OBJECT_ADMISSION_NOT_YET_VALID")
+        if admission_valid_until is not None and now.value >= admission_valid_until.value:
+            raise ObjectAdmissionDenied("OBJECT_ADMISSION_EXPIRED")
+        deletion = self._latest_deletion_row(conn, str(row["blob_digest"]))
+        if deletion is not None and str(deletion["state"]) in {
+            DeletionState.TOMBSTONED.value,
+            DeletionState.PHYSICALLY_REMOVED.value,
+        }:
+            raise ObjectAdmissionDenied("OBJECT_TOMBSTONED")
+        if require_bytes:
+            if str(row["blob_state"]) != BlobLifecycleState.ACTIVE.value:
+                raise ObjectAdmissionDenied("BLOB_NOT_ACTIVE")
+            if (
+                str(row["blob_integrity_state"])
+                != BlobIntegrityState.VERIFIED.value
+            ):
+                raise ObjectIntegrityError("blob integrity is not verified")
+        return row
+
+    def resolve(self, admission_id: object) -> ObjectAdmissionDescriptor:
+        """Internal current-state lookup used by the A1 command boundary."""
+
+        if not isinstance(admission_id, ObjectAdmissionId):
+            raise TypeError("admission lookup requires ObjectAdmissionId")
+        now = self._clock()
+        with self._lock:
+            row = self._current_admission_row(
+                self._connection,
+                str(admission_id),
+                now=now,
+                require_active=True,
+                require_bytes=True,
+            )
+            identity = BlobIdentity(
+                str(row["blob_digest"]), int(row["size_bytes"])
+            )
+            with self._cas.pin(identity):
+                pass
+            return ObjectAdmissionDescriptor(
+                admission_id=admission_id,
+                blob_digest=identity.blob_digest,
+                object_class=str(row["object_class"]),
+                allowed_use=str(row["allowed_use"]),
+                security_scope=str(row["security_scope"]),
+                retention_scope=str(row["retention_scope"]),
+                active=True,
+            )
+
+    def admission_view(self, admission_id: ObjectAdmissionId) -> ObjectAdmissionView:
+        now = self._clock()
+        with self._lock:
+            row = self._current_admission_row(
+                self._connection,
+                str(admission_id),
+                now=now,
+                require_active=False,
+                require_bytes=False,
+            )
+            return self._admission_view_from_row(row)
+
+    @staticmethod
+    def _admission_view_from_row(row: sqlite3.Row) -> ObjectAdmissionView:
+        return ObjectAdmissionView(
+            admission_id=ObjectAdmissionId.parse(str(row["admission_id"])),
+            admission_type=str(row["admission_type"]),
+            definition_version=str(row["definition_version"]),
+            definition_digest=str(row["definition_digest"]),
+            blob=BlobIdentity(
+                str(row["blob_digest"]), int(row["size_bytes"])
+            ),
+            object_class=str(row["object_class"]),
+            allowed_use=str(row["allowed_use"]),
+            security_scope=str(row["security_scope"]),
+            retention_scope=str(row["retention_scope"]),
+            rights_decision_id=RightsDecisionId.parse(
+                str(row["rights_decision_id"])
+            ),
+            rights_decision_digest=str(row["rights_decision_digest"]),
+            valid_from=UtcTimestamp.parse(str(row["valid_from"])),
+            valid_until=(
+                None
+                if row["valid_until"] is None
+                else UtcTimestamp.parse(str(row["valid_until"]))
+            ),
+            lifecycle_version=int(row["admission_lifecycle_version"]),
+            state=AdmissionState(str(row["admission_state"])),
+            activation_event_id=(
+                None
+                if row["admission_event_id"] is None
+                else EventId.parse(str(row["admission_event_id"]))
+            ),
+        )
+
+    def rights_view(self, rights_decision_id: RightsDecisionId) -> RightsDecisionView:
+        with self._lock:
+            row = self._connection.execute(
+                "SELECT * FROM object_rights_decisions WHERE rights_decision_id=?",
+                (str(rights_decision_id),),
+            ).fetchone()
+            if row is None:
+                raise KeyError(str(rights_decision_id))
+            value = self._require_canonical_record(row)
+            if value.get("rights_decision_id") != str(rights_decision_id):
+                raise AuthorityPersistenceError(
+                    "rights decision canonical identity mismatch"
+                )
+            return RightsDecisionView(
+                rights_decision_id=rights_decision_id,
+                authentication_context_id=(
+                    __import__(
+                        "newsroom.authority.types",
+                        fromlist=["AuthenticationContextId"],
+                    ).AuthenticationContextId.parse(
+                        str(row["authentication_context_id"])
+                    )
+                ),
+                authorization_request_digest=str(
+                    row["authorization_request_digest"]
+                ),
+                authorization_decision_id=(
+                    __import__(
+                        "newsroom.authority.types",
+                        fromlist=["AuthorizationDecisionId"],
+                    ).AuthorizationDecisionId.parse(
+                        str(row["authorization_decision_id"])
+                    )
+                ),
+                rights_request_digest=str(row["rights_request_digest"]),
+                policy_contract_digest=str(row["policy_contract_digest"]),
+                admission_definition_digest=str(
+                    row["admission_definition_digest"]
+                ),
+                blob=BlobIdentity(
+                    str(row["blob_digest"]), int(row["size_bytes"])
+                ),
+                object_class=str(row["object_class"]),
+                allowed_use=str(row["allowed_use"]),
+                security_scope=str(row["security_scope"]),
+                retention_scope=str(row["retention_scope"]),
+                allowed=bool(row["allowed"]),
+                reason_code=str(row["reason_code"]),
+                decided_at=UtcTimestamp.parse(str(row["decided_at"])),
+                valid_from=UtcTimestamp.parse(str(row["valid_from"])),
+                valid_until=(
+                    None
+                    if row["valid_until"] is None
+                    else UtcTimestamp.parse(str(row["valid_until"]))
+                ),
+                canonical_digest=str(row["canonical_digest"]),
+            )
+
+    @contextmanager
+    def _object_payload_commit_guard(
+        self, conn: sqlite3.Connection, grant: _AuthorizedCommandGrant
+    ) -> Iterator[_PinnedBlob]:
+        payload = grant.payload
+        if payload.kind != PayloadMode.OBJECT_ADMISSION.value:
+            raise UnsupportedPayloadMode("object payload guard called for other mode")
+        if payload.object_admission_id is None:
+            raise AuthorityPersistenceError(
+                "object payload requires admission identity"
+            )
+        now = self._clock()
+        row = self._current_admission_row(
+            conn,
+            str(payload.object_admission_id),
+            now=now,
+            require_active=True,
+            require_bytes=True,
+        )
+        expected = (
+            str(row["blob_digest"]) == payload.digest
+            and str(row["object_class"]) == payload.object_class
+            and str(row["allowed_use"]) == payload.allowed_use
+            and str(row["security_scope"]) == grant.definition.security_scope
+            and str(row["retention_scope"])
+            == grant.definition.retention_scope
+            and str(row["object_class"])
+            == grant.definition.required_object_class
+            and str(row["allowed_use"])
+            == grant.definition.required_allowed_use
+        )
+        if not expected:
+            raise ObjectAdmissionDenied(
+                "object payload differs from current admitted use"
+            )
+        identity = BlobIdentity(
+            str(row["blob_digest"]), int(row["size_bytes"])
+        )
+        pinned = self._cas.pin(identity)
+        try:
+            yield pinned
+        finally:
+            pinned.close()
+
+    def _final_object_payload_commit_check(
+        self,
+        conn: sqlite3.Connection,
+        grant: _AuthorizedCommandGrant,
+        pinned: _PinnedBlob,
+    ) -> None:
+        if grant.payload.object_admission_id is None:
+            raise AuthorityPersistenceError("missing object admission identity")
+        self._current_admission_row(
+            conn,
+            str(grant.payload.object_admission_id),
+            now=self._clock(),
+            require_active=True,
+            require_bytes=True,
+        )
+        self._cas.verify_pinned(pinned)
+
+    def object_liveness(
+        self, conn: sqlite3.Connection, blob_digest: str
+    ) -> ObjectLivenessSnapshot:
+        active = int(
+            conn.execute(
+                "SELECT COUNT(*) FROM object_admissions a "
+                "JOIN object_admission_heads h ON h.admission_id=a.admission_id "
+                "JOIN object_admission_versions v "
+                "ON v.admission_id=h.admission_id "
+                "AND v.lifecycle_version=h.current_version "
+                "WHERE a.blob_digest=? AND v.state='ACTIVE'",
+                (blob_digest,),
+            ).fetchone()[0]
+        )
+        pending = int(
+            conn.execute(
+                "SELECT COUNT(*) FROM object_admissions a "
+                "JOIN object_admission_heads h ON h.admission_id=a.admission_id "
+                "JOIN object_admission_versions v "
+                "ON v.admission_id=h.admission_id "
+                "AND v.lifecycle_version=h.current_version "
+                "WHERE a.blob_digest=? AND v.state='PENDING'",
+                (blob_digest,),
+            ).fetchone()[0]
+        )
+        references = int(
+            conn.execute(
+                "SELECT COUNT(*) FROM authority_payloads p "
+                "JOIN object_admissions a "
+                "ON a.admission_id=p.object_admission_id "
+                "WHERE a.blob_digest=?",
+                (blob_digest,),
+            ).fetchone()[0]
+        )
+        pins = int(
+            conn.execute(
+                "SELECT COUNT(*) FROM object_recovery_pins p "
+                "JOIN object_recovery_pin_heads h ON h.pin_id=p.pin_id "
+                "JOIN object_recovery_pin_versions v "
+                "ON v.pin_id=h.pin_id AND v.lifecycle_version=h.current_version "
+                "WHERE p.blob_digest=? AND v.state='ACTIVE'",
+                (blob_digest,),
+            ).fetchone()[0]
+        )
+        deletion = self._latest_deletion_row(conn, blob_digest)
+        return ObjectLivenessSnapshot(
+            active_admissions=active,
+            pending_admissions=pending,
+            authority_references=references,
+            active_recovery_pins=pins,
+            deletion_state=(
+                None
+                if deletion is None
+                else DeletionState(str(deletion["state"]))
+            ),
+        )
+
+
+__all__ = ["_ObjectStoreBase"]
