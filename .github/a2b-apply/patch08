+                    "reason_code,recorded_at,detail_digest) VALUES(?,?,?,?,?,?,?,?)",
+                    (
+                        str(admission_id),
+                        next_version,
+                        AdmissionState.REVOKED.value,
+                        str(grant.operation_id),
