+    def commit_admission(
+        self,
+        grant: _AdmissionCommitGrant,
+        *,
+        lifecycle_grant_factory: Callable[
+            [ObjectAdmissionId, RightsDecisionId, dict[str, object]],
+            _AuthorizedCommandGrant,
